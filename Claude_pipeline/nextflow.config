/*
 * metastasis-length-pipeline (Xena) — config
 */

params {
    // --- Xena source selection ---------------------------------------------
    // Host is one of: publicHub, tcgaHub, gdcHub, toilHub, pancanAtlasHub,
    //                 treehouseHub, atacseqHub, singlecellHub
    // See UCSCXenaTools::XenaData for available datasets.
    //
    // Three convenient presets; override them with --xena_host / --xena_dataset
    // / --xena_phenotype to use any other Xena cohort.
    preset = 'skcm'        // skcm | pancan_toil | custom

    // Used when preset == 'custom'. For all presets, these override defaults.
    xena_host       = null
    xena_dataset    = null
    xena_phenotype  = null

    // Data type: 'counts_log2' (Toil RSEM expected_count, stored as log2(x+1))
    //            'log2_norm'   (legacy TCGA log2(norm_count+1))
    //            'counts_raw'  (rare — raw integer counts)
    // Determines whether voom or limma-trend is used.
    data_type = null       // auto-inferred from preset unless set

    // Sample filtering
    // TCGA sample-type codes to use as 'primary' and 'metastasis'
    primary_codes    = '01'       // comma-sep: 01 = Primary Solid Tumor
    metastasis_codes = '06,07'    // 06 = Metastatic, 07 = Additional Metastatic
    // Optional: restrict to specific cancer types (for pancan_toil / custom)
    cancer_types     = null       // e.g. 'TCGA-SKCM,TCGA-BRCA'

    // --- Analysis params ---------------------------------------------------
    genome_build = 'hg38'
    gene_id_type = 'geneSymbol'   // SKCM/Toil-Hugo use symbols; use 'ensGene' for ENSG
    fdr_cutoff   = 0.05
    lfc_cutoff   = 1.0

    // Optional override: TSV of gene_id<TAB>length_bp. If null, goseq::getlength is used.
    gene_lengths = null

    outdir = 'results'
}

// --- Preset expansion ---------------------------------------------------
// Picks up after profile/CLI overrides.
if (params.preset == 'skcm' && !params.xena_dataset) {
    params.xena_host      = 'tcgaHub'
    params.xena_dataset   = 'TCGA.SKCM.sampleMap/HiSeqV2'
    params.xena_phenotype = 'TCGA.SKCM.sampleMap/SKCM_clinicalMatrix'
    if (!params.data_type) params.data_type = 'log2_norm'
} else if (params.preset == 'pancan_toil' && !params.xena_dataset) {
    params.xena_host      = 'toilHub'
    params.xena_dataset   = 'TcgaTargetGtex_RSEM_Hugo_norm_count'
    params.xena_phenotype = 'TcgaTargetGTEX_phenotype.txt'
    if (!params.data_type) params.data_type = 'log2_norm'
}

profiles {
    standard    { process.executor = 'local' }
    slurm       {
        process.executor = 'slurm'
        process.queue    = 'normal'
    }
    conda {
        conda.enabled  = true
        conda.useMamba = true
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }
}

process {
    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode: 'copy'
    ]
    errorStrategy = { task.exitStatus in [137,140,143] ? 'retry' : 'finish' }
    maxRetries    = 2

    withName: 'XENA_DOWNLOAD'         { cpus = 2; memory = '8 GB'; time = '4h' }
    withName: 'LIMMA_LENGTH_ANALYSIS' { cpus = 4; memory = '32 GB'; time = '4h' }
}

manifest {
    name            = 'metastasis-length-pipeline-xena'
    author          = 'jccdigital'
    description     = 'UCSC Xena -> limma-voom/trend DE + gene-length bias analysis'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '0.2.0'
}
